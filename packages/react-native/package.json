{
  "name": "@retailcode/react-native",
  "version": "0.1.0",
  "description": "Retailcode SDK — React Native components",
  "license": "MIT",
  "homepage": "https://github.com/retailcode/sdk",
  "repository": { "type": "git", "url": "https://github.com/retailcode/sdk.git", "directory": "packages/react-native" },
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retailcode/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "devDependencies": {
    "@types/react": "^19.1.1",
    "tsup": "*",
    "typescript": "*"
  }
}
